PORT=8787
DATABASE_PATH=/data/house.db
HOUSE_SETUP_SECRET=replace-with-long-random-string
TOKEN_HASH_SECRET=replace-with-another-long-random-string
PAIRING_CODE_TTL_MINUTES=10

# Optional remote access with Cloudflare Tunnel.
# Never commit a real tunnel token.
CLOUDFLARE_TUNNEL_TOKEN=
# Public HTTPS URL shown on the setup page and used by the mobile app in remote mode.
PUBLIC_BASE_URL=
# Optional override for ./create-pairing-code.sh. Defaults to http://127.0.0.1:$PORT.
PAIRING_CODE_SERVER_URL=
# Comma-separated browser origins allowed by CORS. Leave empty for permissive LAN/dev.
ALLOWED_ORIGINS=

HERMES_COMMAND_MODE=mock
HERMES_HOST_DIR=/home/pi/.hermes
HERMES_CONTAINER_DIR=/home/pi/.hermes
UV_PYTHON_HOST_DIR=/home/pi/.local/share/uv
UV_PYTHON_CONTAINER_DIR=/home/pi/.local/share/uv
HERMES_HOME=/home/pi/.hermes
HERMES_WORKING_DIRECTORY=/home/pi/.hermes/hermes-agent
HERMES_PYTHON_PATH=/home/pi/.hermes/hermes-agent/venv/bin/python
HERMES_TIMEOUT_SECONDS=120
