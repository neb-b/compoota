{
  "expo": {
    "name": "compoota",
    "slug": "compoota",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "jsEngine": "hermes",
    "scheme": "compoota",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.neb.compoota",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "compoota connects to your local house-server on your LAN.",
        "NSCameraUsageDescription": "compoota uses the camera so you can attach photos for Hermes to analyze.",
        "NSPhotoLibraryUsageDescription": "compoota uses your photo library so you can choose photos for Hermes to analyze.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "compoota uses your photo library so you can choose photos for Hermes to analyze.",
          "cameraPermission": "compoota uses the camera so you can attach photos for Hermes to analyze."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#405871",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 393,
          "resizeMode": "cover",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 393,
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6b1bb507-3607-4abb-af11-a164fc717434"
      }
    },
    "owner": "seanyesmunt"
  }
}
